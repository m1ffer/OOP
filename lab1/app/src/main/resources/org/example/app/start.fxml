<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="400.0" prefWidth="600.0"
      spacing="20"
      alignment="CENTER"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controllers.StartController">

    <children>

        <Button fx:id="startTxt"
                text="Запустить анимацию из TXT"
                onAction="#handleStartFromTxt"/>

        <Button text="Запустить анимацию из JSON"
                onAction="#handleStartFromJson"/>

        <Button text="Конфигурировать анимацию"
                onAction="#handleConfigure"/>

    </children>

</VBox>